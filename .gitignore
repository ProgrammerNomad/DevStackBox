# DevStackBox - .gitignore
# =================================

# Node.js Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Electron Build Output
dist/
build/
release/
out/

# Electron Cache
.electron-vue/
.electron-builder/

# Runtime Data
pids
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
.nyc_output
*.lcov

# Logs
logs/
*.log
lerna-debug.log*

# Environment Variables
.env
.env.local
.env.*.local

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*~

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# DevStackBox Specific Files
# ===========================

# Portable Server Binaries (if added)
apache/bin/
apache/modules/
apache/htdocs/
mysql/bin/
mysql/data/
mysql/lib/
mysql/share/
php/*/
phpmyadmin/vendor/
phpmyadmin/tmp/

# Configuration Backups
*.ini.bak
*.conf.bak
*.cnf.bak

# Server Logs
apache/logs/
mysql/logs/
logs/
*.error.log
*.access.log

# Temporary Files
tmp/
temp/
*.tmp
*.temp

# Database Files
*.sql
*.db
*.sqlite
*.sqlite3

# User Projects (optional - uncomment if you want to ignore user projects)
# www/projects/*/

# Build Tools Cache
.cache/
.parcel-cache/

# Package Files
*.tgz
*.tar.gz
*.zip
*.rar

# ESLint Cache
.eslintcache

# Optional: Keep README files in empty directories
!apache/README.md
!mysql/README.md
!php/README.md
!phpmyadmin/README.md
!apps/README.md
!www/README.md

# Keep asset files
!assets/icon.png
!assets/logo.png
!assets/tray-icon.png
