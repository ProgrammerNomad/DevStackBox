# DevStackBox - .gitignore
# =================================

# Node.js Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Electron Build Output
dist/
build/
release/
out/

# Electron Cache
.electron-vue/
.electron-builder/

# Runtime Data
pids
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
.nyc_output
*.lcov

# Logs
logs/
*.log
lerna-debug.log*

# Environment Variables
.env
.env.local
.env.*.local

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*~

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# DevStackBox Specific Files
# ===========================

# 🎯 SERVER BINARIES ARE INCLUDED IN REPOSITORY
# Apache, MySQL, PHP, and phpMyAdmin binaries are pre-bundled for immediate use

# Only exclude runtime data and logs (not the server binaries themselves):
mysql/data/*
!mysql/data/.gitkeep
apache/logs/*
!apache/logs/.gitkeep
mysql/logs/*  
!mysql/logs/.gitkeep
php/*/logs/*
!php/*/logs/.gitkeep

# Configuration Backups
*.ini.bak
*.conf.bak
*.cnf.bak

# Large Debug Files (Not needed for runtime)
*.pdb
*.ilk
*.exp
*.lib

# Large Binary Files (Optional for server operation)
# Uncomment the following lines if MySQL executable is too large for your git hosting:
# mysql/bin/mysqld.exe

# Server Runtime Logs
logs/
*.error.log
*.access.log

# Temporary Files
tmp/
temp/
*.tmp
*.temp

# Database Files (user data)
*.sql
*.db
*.sqlite
*.sqlite3

# User Projects (optional - uncomment if you want to ignore user projects)
# www/projects/*/

# Build Tools Cache
.cache/
.parcel-cache/

# Package Files
*.tgz
*.tar.gz
*.zip
*.rar

# ESLint Cache
.eslintcache

# Keep Important Files
!apache/README.md
!mysql/README.md
!php/README.md
!phpmyadmin/README.md
!apps/README.md
!www/README.md

# Keep Asset Files
!assets/icon.png
!assets/logo.png
!assets/tray-icon.png
